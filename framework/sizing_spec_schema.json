        },
        "document_ai": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "compute_hours_monthly": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "ai_parse_document_layout": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "pages_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "ai_parse_document_ocr": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "pages_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cortex_fine_tuning": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "training_tokens_M": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cortex_functions": {
          "description": "AI_ SQL functions (ai_classify, ai_sentiment, etc.). WRONG: placing these directly under ai_cortex.",
          "type": "object",
          "required": [
            "ai_classify",
            "ai_sentiment",
            "ai_summarize",
            "ai_translate",
            "ai_extract",
            "ai_transcribe"
          ],
          "additionalProperties": false,
          "properties": {
            "ai_classify": {
              "$ref": "#/definitions/cortex_function"
            },
            "ai_sentiment": {
              "$ref": "#/definitions/cortex_function"
            },
            "ai_summarize": {
              "$ref": "#/definitions/cortex_function"
