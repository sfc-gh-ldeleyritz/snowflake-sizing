{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SIZING_SPEC",
  "description": "Canonical schema for the snowflake-sizing SIZING_SPEC JSON artifact produced by the snowflake-sizing skill. Consumed by hooks/sizing-guard.py on every Write to sizings/*.json.",
  "type": "object",
  "required": [
    "meta",
    "workloads",
    "serverless",
    "ai_cortex",
    "storage",
    "assumptions",
    "confirm_required"
  ],
  "additionalProperties": true,
  "definitions": {
    "source_field": {
      "type": "string",
      "enum": [
        "SOURCED",
        "ASSUMPTION",
        "ESTIMATED"
      ]
    },
    "ramp_curve": {
      "type": "string",
      "enum": [
        "fastest",
        "fast",
        "linear",
        "slow",
        "slowest"
      ]
    },
    "wh_size_abbreviated": {
      "description": "Abbreviated warehouse size used in workloads and collaboration.reader_accounts.",
      "type": "string",
      "enum": [
        "XS",
        "S",
        "M",
        "L",
        "XL",
        "2XL",
        "3XL",
        "4XL",
        "5XL",
        "6XL"
      ]
    },
    "wh_size_full": {
      "description": "Full warehouse size name required for OpenFlow instances (JS billing lookup uses full string).",
      "type": "string",
      "enum": [
        "X-Small",
        "Small",
        "Medium",
        "Large",
        "X-Large",
        "2X-Large",
        "3X-Large",
        "4X-Large"
      ]
    },
    "serverless_compute": {
      "description": "Basic serverless feature with enabled flag and compute hours.",
      "type": "object",
      "required": [
        "enabled",
        "compute_hours_monthly"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "compute_hours_monthly": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "serverless_compute_sourced": {
      "description": "Serverless feature with sourcing metadata.",
      "type": "object",
      "required": [
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "compute_hours_monthly": {
          "type": "number",
          "minimum": 0
        },
        "source": {
          "$ref": "#/definitions/source_field"
        },
        "justification": {
          "type": "string"
        }
      }
    },
    "cortex_function": {
      "description": "AI_ SQL function under ai_cortex.cortex_functions.",
      "type": "object",
      "required": [
        "enabled",
        "tokens_M_monthly"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "tokens_M_monthly": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "cortex_code_surface": {
      "description": "One Cortex Code surface (CLI / Snowsight / Desktop).",
      "type": "object",
      "required": [
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "developers": {
          "type": "integer",
          "minimum": 0
        },
        "queries_per_dev_per_day": {
          "type": "number",
          "minimum": 0
        },
        "avg_tokens_per_query": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  },
  "properties": {
    "meta": {
      "description": "Deal metadata: customer identity, Snowflake configuration, pricing rates, and contract terms.",
      "type": "object",
      "required": [
        "customer",
        "edition",
        "cloud",
        "region",
        "credit_rate",
        "ai_credit_rate",
        "storage_rate_per_tb",
        "hybrid_tables_storage_rate_per_gb",
        "contract_years",
        "generated_date",
        "default_ramp_curve",
        "annual_growth_rate"
      ],
      "additionalProperties": false,
      "properties": {
        "customer": {
          "type": "string"
        },
        "edition": {
          "type": "string",
          "enum": [
            "Standard",
            "Enterprise",
            "Business Critical",
            "VPS"
          ]
        },
        "cloud": {
          "type": "string",
          "enum": [
            "AWS",
            "Azure",
            "GCP"
          ]
        },
        "region": {
          "type": "string"
        },
        "credit_rate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "ai_credit_rate": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "storage_rate_per_tb": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "hybrid_tables_storage_rate_per_gb": {
          "type": "number",
          "minimum": 0
        },
        "contract_years": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "generated_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "ISO 8601 date string YYYY-MM-DD."
        },
        "pdf_version": {
          "type": "string"
        },
        "default_ramp_curve": {
          "$ref": "#/definitions/ramp_curve"
        },
        "default_dev_start_month": {
          "type": "integer",
          "minimum": 0
        },
        "default_go_live_month": {
          "type": "integer",
          "minimum": 1
        },
        "annual_growth_rate": {
          "type": "number",
          "minimum": 0
        },
        "ai_growth_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Optional annual growth rate for AI/Cortex consumption. null (or absent) means AI ramps on meta.annual_growth_rate. Mirrors the JS rampMultiplierForYear AI path."
        },
        "list_credit_rate": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Pre-discount credit rate; present when discount block is active."
        },
        "version_number": {
          "type": "integer",
          "minimum": 1
        },
        "discount": {
          "type": "object",
          "required": [
            "enabled",
            "mode"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "mode": {
              "type": "string",
              "enum": [
                "percent",
                "rate"
              ]
            },
            "percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "rate": {
              "type": [
                "number",
                "null"
              ],
              "minimum": 0
            }
          }
        }
      }
    },
    "workloads": {
      "description": "Virtual warehouse workloads. MUST be 'workloads' \u2014 never 'warehouses'.",
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "size",
          "hours_per_day",
          "days_per_month",
          "clusters_min",
          "clusters_max",
          "auto_suspend_seconds",
          "source",
          "ramp_curve",
          "dev_start_month",
          "go_live_month"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "size": {
            "$ref": "#/definitions/wh_size_abbreviated"
          },
          "hours_per_day": {
            "type": "number",
            "minimum": 0
          },
          "days_per_month": {
            "type": "number",
            "minimum": 0,
            "maximum": 31
          },
          "clusters_min": {
            "type": "integer",
            "minimum": 1
          },
          "clusters_max": {
            "type": "integer",
            "minimum": 1
          },
          "auto_suspend_seconds": {
            "type": "integer",
            "minimum": 0
          },
          "source": {
            "$ref": "#/definitions/source_field"
          },
          "justification": {
            "type": "string"
          },
          "ramp_curve": {
            "$ref": "#/definitions/ramp_curve"
          },
          "dev_start_month": {
            "type": "integer",
            "minimum": 0
          },
          "go_live_month": {
            "type": "integer",
            "minimum": 1
          },
          "growth_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 5,
            "description": "Optional per-workload annual growth rate. When absent, this workload ramps on meta.annual_growth_rate. Precedence in the JS render is scenario growthOverride > workload growth_rate > meta.annual_growth_rate."
          },
          "gen": {
            "type": "integer",
            "enum": [1, 2],
            "description": "Standard-warehouse generation: 1 = Gen1 (default), 2 = Gen2 (per-cloud rates). Ignored for snowpark warehouses."
          },
          "warehouse_type": {
            "type": "string",
            "enum": ["standard", "snowpark"],
            "description": "Warehouse type: 'standard' (default) or 'snowpark' (Snowpark-Optimized)."
          },
          "memory_config": {
            "type": "string",
            "description": "Snowpark-Optimized memory configuration (e.g. MEMORY_1X, MEMORY_1X_x86, MEMORY_16X). Only used when warehouse_type='snowpark'."
          }
        }
      }
    },
    "serverless": {
      "description": "Snowflake serverless features. Each sub-key must be present (set enabled:false if not used).",
      "type": "object",
      "required": [
        "snowpipe",
        "snowpipe_streaming",
        "snowpipe_streaming_classic",
        "serverless_tasks",
        "serverless_tasks_flex",
        "serverless_alerts",
        "clustered_tables",
        "materialized_views",
        "search_optimization",
        "query_acceleration",
        "replication",
        "backup",
        "failsafe_recovery",
        "data_quality_monitoring",
        "trust_center",
        "table_optimization",
        "storage_lifecycle_policy",
        "hybrid_tables_requests",
        "copy_files",
        "automated_refresh",
        "organization_usage",
        "sensitive_data_classification",
        "open_catalog",
        "logging",
        "telemetry_data_ingest",
        "archive_storage_retrieval",
        "archive_storage_write"
      ],
      "additionalProperties": false,
      "properties": {
        "snowpipe": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "files_per_month": {
              "type": "number",
              "minimum": 0
            },
            "gb_per_month": {
              "type": "number",
              "minimum": 0
            },
            "source": {
              "$ref": "#/definitions/source_field"
            },
            "justification": {
              "type": "string"
            }
          }
        },
        "snowpipe_streaming": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "uncompressed_gb_per_month": {
              "type": "number",
              "minimum": 0
            },
            "source": {
              "$ref": "#/definitions/source_field"
            },
            "justification": {
              "type": "string"
            }
          }
        },
        "snowpipe_streaming_classic": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "client_instances": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "serverless_tasks": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "compute_hours_monthly": {
              "type": "number",
              "minimum": 0
            },
            "source": {
              "$ref": "#/definitions/source_field"
            },
            "justification": {
              "type": "string"
            }
          }
        },
        "serverless_tasks_flex": {
          "$ref": "#/definitions/serverless_compute"
        },
        "serverless_alerts": {
          "$ref": "#/definitions/serverless_compute"
        },
        "clustered_tables": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "compute_hours_monthly": {
              "type": "number",
              "minimum": 0
            },
            "source": {
              "$ref": "#/definitions/source_field"
            },
            "justification": {
              "type": "string"
            }
          }
        },
        "materialized_views": {
          "$ref": "#/definitions/serverless_compute"
        },
        "search_optimization": {
          "$ref": "#/definitions/serverless_compute"
        },
        "query_acceleration": {
          "$ref": "#/definitions/serverless_compute"
        },
        "replication": {
          "$ref": "#/definitions/serverless_compute"
        },
        "backup": {
          "$ref": "#/definitions/serverless_compute"
        },
        "failsafe_recovery": {
          "$ref": "#/definitions/serverless_compute"
        },
        "data_quality_monitoring": {
          "$ref": "#/definitions/serverless_compute"
        },
        "trust_center": {
          "$ref": "#/definitions/serverless_compute"
        },
        "table_optimization": {
          "$ref": "#/definitions/serverless_compute"
        },
        "storage_lifecycle_policy": {
          "$ref": "#/definitions/serverless_compute"
        },
        "hybrid_tables_requests": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "reads_gb_monthly": {
              "type": "number",
              "minimum": 0
            },
            "writes_gb_monthly": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "copy_files": {
          "$ref": "#/definitions/serverless_compute"
        },
        "automated_refresh": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "files_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "organization_usage": {
          "$ref": "#/definitions/serverless_compute"
        },
        "sensitive_data_classification": {
          "$ref": "#/definitions/serverless_compute"
        },
        "open_catalog": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "requests_per_month_M": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "logging": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "file_batches_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "telemetry_data_ingest": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "gb_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "archive_storage_retrieval": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "files_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "archive_storage_write": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "files_per_month": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "ai_cortex": {
      "description": "Snowflake Cortex AI features.",
      "type": "object",
      "required": [
        "cortex_complete",
        "cortex_agents",
        "snowflake_intelligence",
        "cortex_code",
        "cortex_analyst",
        "cortex_search",
        "cortex_fine_tuning",
        "cortex_functions",
        "embeddings"
      ],
      "additionalProperties": false,
      "properties": {
        "cortex_complete": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "model": {
              "type": "string"
            },
            "monthly_input_tokens_M": {
              "type": "number",
              "minimum": 0,
              "description": "Value in millions of tokens. WRONG: 'monthly_tokens_input'."
            },
            "monthly_output_tokens_M": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cortex_agents": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "monthly_input_tokens_M": {
              "type": "number",
              "minimum": 0
            },
            "monthly_output_tokens_M": {
              "type": "number",
              "minimum": 0
            },
            "monthly_users": {
              "type": "integer",
              "minimum": 0
            },
            "sessions_per_user_per_day": {
              "type": "number",
              "minimum": 0
            },
            "messages_per_session": {
              "type": "number",
              "minimum": 0
            },
            "avg_input_tokens_per_message": {
              "type": "number",
              "minimum": 0
            },
            "avg_output_tokens_per_message": {
              "type": "number",
              "minimum": 0
            },
            "working_days_per_month": {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            },
            "model": {
              "type": "string"
            },
            "monthly_cache_write_tokens_M": {
              "type": "number",
              "minimum": 0
            },
            "monthly_cache_read_tokens_M": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "snowflake_intelligence": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "monthly_input_tokens_M": {
              "type": "number",
              "minimum": 0
            },
            "monthly_output_tokens_M": {
              "type": "number",
              "minimum": 0
            },
            "monthly_users": {
              "type": "integer",
              "minimum": 0
            },
            "sessions_per_user_per_day": {
              "type": "number",
              "minimum": 0
            },
            "messages_per_session": {
              "type": "number",
              "minimum": 0
            },
            "avg_input_tokens_per_message": {
              "type": "number",
              "minimum": 0
            },
            "avg_output_tokens_per_message": {
              "type": "number",
              "minimum": 0
            },
            "working_days_per_month": {
              "type": "integer",
              "minimum": 1,
              "maximum": 31
            },
            "model": {
              "type": "string"
            },
            "monthly_cache_write_tokens_M": {
              "type": "number",
              "minimum": 0
            },
            "monthly_cache_read_tokens_M": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cortex_code": {
          "description": "Cortex Code. Two accepted shapes: three-surface {cli,snowsight,desktop} (canonical for new specs) and legacy flat {developers,queries_per_dev_per_day,avg_tokens_per_query} (auto-migrated onto `cli` by the template at render time). compute_totals.py reads surfaces first, then falls back to flat.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "model": {
              "type": "string"
            },
            "developers": {
              "type": "integer",
              "minimum": 0
            },
            "queries_per_dev_per_day": {
              "type": "number",
              "minimum": 0
            },
            "avg_tokens_per_query": {
              "type": "number",
              "minimum": 0
            },
            "cli": {
              "$ref": "#/definitions/cortex_code_surface"
            },
            "snowsight": {
              "$ref": "#/definitions/cortex_code_surface"
            },
            "desktop": {
              "$ref": "#/definitions/cortex_code_surface"
            }
          }
        },
        "cortex_analyst": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "monthly_messages": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "cortex_search": {
          "type": "object",
          "required": [
            "enabled"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "indexed_data_gb": {
              "type": "number",
              "minimum": 0,
